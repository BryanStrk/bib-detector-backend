# Copy this file to `.env` and adjust as needed. NEVER commit a real `.env`.

# Optional path to a YOLO bib-detection model (.pt). When set, the detector
# uses the YOLO -> crop -> EasyOCR pipeline. Leave unset for the EasyOCR MVP.
# MODEL_PATH=models/bib_yolo.pt

# Comma-separated list of allowed CORS origins (frontend URLs).
CORS_ORIGINS=http://localhost:5173,https://bib-detector.example.com

# Discard detections below this confidence (0.0 - 1.0).
MIN_CONFIDENCE=0.3

# Database URL (SQLModel/SQLAlchemy). Defaults to a local SQLite file if unset.
# For Postgres use the psycopg v3 driver, e.g.:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/bib_detector

# Cloudinary credentials. Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
# CLOUDINARY_URL=cloudinary://123456789012345:abcdefghijklmnopqrstuvwxyz0@your-cloud-name

# Maximum accepted upload size in megabytes.
MAX_UPLOAD_MB=10

# --- Admin auth (single user, credentials from env; no user table) ---
# Admin username for the protected endpoints.
ADMIN_USERNAME=admin
# bcrypt hash of the admin password (NEVER plaintext). Generate one with:
#   python scripts/hash_password.py
ADMIN_PASSWORD_HASH=$2b$12$replace_this_with_a_real_bcrypt_hash_generated_by_the_script
# Secret used to sign JWTs. Use a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
